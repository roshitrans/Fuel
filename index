document.addEventListener('DOMContentLoaded', () => {
  // Fuel dashboard init
  historicalPrices = generateHistory(currentPrice);
  forecastPrices   = generateForecast(currentPrice);
  buildChart();
  updateChartStats();
  ['f1','f2','f3'].forEach((id,i) => {
    const p = forecastPrices[i], diff = p-currentPrice, up = diff>=0;
    document.getElementById(id+'Price').textContent = fmt(p);
    const arrow = document.getElementById(id+'Arrow');
    arrow.textContent = up?'↑ Rising':'↓ Dropping';
    arrow.className = 'forecast-arrow '+(up?'arrow-up':'arrow-down');
    document.getElementById(['f1Diff','f2Diff','f3Diff'][i]).textContent =
      (up?'+':'')+'₹'+Math.abs(diff).toFixed(2)+' from today';
  });
  setMeter('slight', null);
  calcFuelCost();

  // Route planner autocomplete
  rpSetupAutocomplete('rp-origin',      'rp-originSuggestions',      c => { rpOriginCoords = c; });
  rpSetupAutocomplete('rp-destination', 'rp-destinationSuggestions', c => { rpDestCoords   = c; });

  // Keyboard nav
  document.getElementById('rp-origin').addEventListener('keypress', e => {
    if (e.key==='Enter') { e.preventDefault(); document.getElementById('rp-destination').focus(); }
  });
  document.getElementById('rp-destination').addEventListener('keypress', e => {
    if (e.key==='Enter' && rpOriginCoords && rpDestCoords) { e.preventDefault(); rpCalculateRoute(); }
  });

  // Cache cleanup
  setInterval(() => {
    const now = Date.now();
    for (const [k,v] of rpSearchCache.entries()) if (now-v.timestamp > RP_CACHE_EXPIRY) rpSearchCache.delete(k);
  }, 600000);
});
