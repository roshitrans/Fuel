/* ═══════════════════════════════════════════
   FUEL DASHBOARD LOGIC
═══════════════════════════════════════════ */
const statePrices = {
  'Rajasthan':94.62,'Delhi':87.62,'Gujarat':93.02,'Maharashtra':90.78,
  'Punjab':95.30,'Haryana':88.97,'Uttar Pradesh':93.45,'Madhya Pradesh':95.10,
  'Karnataka':89.67,'Tamil Nadu':91.23
};
let currentPrice = 94.62, currentState = 'Rajasthan';
let forecastPrices = [], historicalPrices = [], chartInstance = null;

function fmt(n) { return n.toFixed(2); }
function fmtCur(n) { return '₹' + n.toLocaleString('en-IN',{minimumFractionDigits:0,maximumFractionDigits:0}); }

function generateForecast(base) {
  const d = [];
  for (let i=0;i<3;i++) d.push(parseFloat((base+(i+1)*0.15+(Math.random()*1.4-0.3)*0.4).toFixed(2)));
  return d;
}
function generateHistory(base) {
  const d = [];
  for (let i=6;i>=0;i--) d.push(parseFloat((base+(Math.random()*2-1.2)*(i*0.18+0.3)).toFixed(2)));
  d[6] = base; return d;
}

function updatePrice() {
  const v = parseFloat(document.getElementById('manualPrice').value);
  if (isNaN(v)||v<50||v>200){alert('Please enter a valid diesel price (₹50–₹200).');return;}
  currentPrice = v; applyUpdate();
}
function updateState() {
  currentState = document.getElementById('stateSelect').value;
  currentPrice = statePrices[currentState]||94.62;
  document.getElementById('manualPrice').value = fmt(currentPrice);
  applyUpdate();
}
function applyUpdate() {
  document.getElementById('currentPriceDisplay').textContent = fmt(currentPrice);
  document.getElementById('locationDisplay').textContent = currentState;
  const now = new Date();
  document.getElementById('lastUpdated').textContent =
    'Last updated: '+now.toLocaleDateString('en-IN',{day:'numeric',month:'short'})+
    ', '+now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})+' IST';
  forecastPrices = generateForecast(currentPrice);
  ['f1','f2','f3'].forEach((id,i)=>{
    const p = forecastPrices[i], diff = p-currentPrice, up = diff>=0;
    document.getElementById(id+'Price').textContent = fmt(p);
    const arrow = document.getElementById(id+'Arrow');
    arrow.textContent = up?'↑ Rising':'↓ Dropping';
    arrow.className = 'forecast-arrow '+(up?'arrow-up':'arrow-down');
    document.getElementById(['f1Diff','f2Diff','f3Diff'][i]).textContent =
      (up?'+':'')+'₹'+Math.abs(diff).toFixed(2)+' from today';
  });
  historicalPrices = generateHistory(currentPrice);
  updateChart(); updateChartStats(); calcFuelCost(); calcRoute();
}

function buildChart() {
  const labels = [];
  for (let i=6;i>=0;i--){const d=new Date();d.setDate(d.getDate()-i);labels.push(d.toLocaleDateString('en-IN',{day:'numeric',month:'short'}));}
  const ctx = document.getElementById('trendChart').getContext('2d');
  const grad = ctx.createLinearGradient(0,0,0,200);
  grad.addColorStop(0,'rgba(227,178,9,0.22)'); grad.addColorStop(1,'rgba(227,178,9,0.01)');
  chartInstance = new Chart(ctx,{type:'line',data:{labels,datasets:[{label:'Diesel Price (₹/L)',data:historicalPrices,borderColor:'#E3B209',backgroundColor:grad,borderWidth:2.5,pointBackgroundColor:'#E3B209',pointBorderColor:'#fff',pointBorderWidth:2,pointRadius:4,pointHoverRadius:6,fill:true,tension:0.4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'rgba(44,26,6,0.92)',titleFont:{family:'Syne',size:12,weight:'700'},bodyFont:{family:'DM Sans',size:13},titleColor:'#EDCE4D',bodyColor:'#F8F0E2',padding:12,cornerRadius:8,displayColors:false,callbacks:{label:ctx=>'₹'+ctx.raw+' / litre'}}},scales:{x:{grid:{color:'rgba(163,107,35,0.08)',drawBorder:false},ticks:{color:'#A38054',font:{family:'DM Sans',size:11}}},y:{grid:{color:'rgba(163,107,35,0.08)',drawBorder:false},ticks:{color:'#A38054',font:{family:'DM Sans',size:11},callback:v=>'₹'+v},suggestedMin:parseFloat((Math.min(...historicalPrices)-1).toFixed(0)),suggestedMax:parseFloat((Math.max(...historicalPrices)+1).toFixed(0))}}}});
}
function updateChart() {
  if(!chartInstance)return;
  chartInstance.data.datasets[0].data = historicalPrices;
  chartInstance.options.scales.y.suggestedMin = parseFloat((Math.min(...historicalPrices)-1).toFixed(0));
  chartInstance.options.scales.y.suggestedMax = parseFloat((Math.max(...historicalPrices)+1).toFixed(0));
  chartInstance.update();
}
function updateChartStats() {
  const hi=Math.max(...historicalPrices,...forecastPrices), lo=Math.min(...historicalPrices);
  document.getElementById('chartHigh').textContent='₹'+fmt(hi);
  document.getElementById('chartLow').textContent='₹'+fmt(lo);
}

function setMeter(type,evt) {
  const configs = {
    stable:{rotation:'-90deg',label:'Stable',desc:'Diesel prices are stable. No immediate surge expected. Standard fuel planning recommended.',g:'1',y:'0',o:'0',r:'0'},
    slight:{rotation:'-30deg',label:'Slight Rise',desc:"Prices are showing a mild upward trend. Consider filling fuel tanks before tomorrow's potential rise.",g:'1',y:'1',o:'0',r:'0'},
    high:{rotation:'30deg',label:'High Rise Expected',desc:'Significant price rise anticipated. Fill all available fuel tanks now to minimize operational costs.',g:'1',y:'1',o:'1',r:'0'},
    drop:{rotation:'85deg',label:'Possible Drop',desc:'Market signals suggest a possible price reduction. Consider delaying bulk refueling if operationally feasible.',g:'0',y:'0',o:'0',r:'1'}
  };
  const c = configs[type];
  document.getElementById('gaugeNeedle').style.transform = `rotate(${c.rotation})`;
  document.getElementById('gaugeStatus').textContent = c.label;
  document.getElementById('meterDesc').textContent = c.desc;
  [['gaugeGreen',c.g],['gaugeYellow',c.y],['gaugeOrange',c.o],['gaugeRed',c.r]].forEach(([id,v])=>document.getElementById(id).style.opacity=v);
  document.querySelectorAll('.meter-pill').forEach(p=>p.classList.remove('pill-active'));
  if(evt&&evt.target) evt.target.classList.add('pill-active');
}

function calcFuelCost() {
  const trucks=parseInt(document.getElementById('numTrucks').value)||0;
  const tank=parseInt(document.getElementById('tankCap').value)||0;
  const total=trucks*tank;
  document.getElementById('calcSubtext').textContent=`${trucks} truck${trucks!==1?'s':''} × ${tank}L = ${total.toLocaleString('en-IN')}L total`;
  document.getElementById('extraCost').textContent=fmtCur(total);
}

function toggleTransport() {
  const on=document.getElementById('transportToggle').checked;
  document.getElementById('routeForm').className=on?'route-form visible':'route-form';
  const s=document.getElementById('transportStatus');
  s.textContent=on?'ON':'OFF'; s.className=on?'toggle-status active':'toggle-status';
}
function calcRoute() {
  const from=document.getElementById('startCity').value.trim()||'Start';
  const to=document.getElementById('destCity').value.trim()||'Destination';
  const dist=parseFloat(document.getElementById('tripDist').value)||0;
  const mpg=parseFloat(document.getElementById('mileage').value)||5;
  const result=document.getElementById('routeResult');
  if(!dist||!mpg){result.style.display='none';return;}
  const litres=(dist/mpg).toFixed(1);
  const cost=(litres*currentPrice).toFixed(0);
  document.getElementById('routeStation').textContent=from+' → '+to;
  document.getElementById('routeDiesel').textContent=litres+' L';
  document.getElementById('routeCost').textContent=fmtCur(parseFloat(cost));
  result.style.display='grid';
}

function shareWhatsApp(e) {
  e.preventDefault();
  const f1=forecastPrices[0]||(currentPrice+0.23);
  const rec=f1>currentPrice?'Fill Today — Prices Rising Tomorrow 🔺':'Monitor — Prices May Drop Tomorrow 🔻';
  const msg=`🚛 *Diesel Rate Update*\n━━━━━━━━━━━━━━\n📍 *Location:* ${currentState}\n\n⛽ *Today:* ₹${fmt(currentPrice)} / L\n📈 *Tomorrow Expected:* ₹${fmt(f1)} / L\n\n✅ *Recommendation:*\n${rec}\n\n━━━━━━━━━━━━━━\n🏢 Shared by *Roshi Transport Corporation*\n🔗 India Diesel Intelligence Dashboard`;
  window.open('https://api.whatsapp.com/send?text='+encodeURIComponent(msg),'_blank');
}

/* ═══════════════════════════════════════════
   ROUTE PLANNER LOGIC (exact from original)
═══════════════════════════════════════════ */
let rpMap, rpRouteLayer, rpOriginMarker, rpDestMarker;
let rpOriginCoords = null, rpDestCoords = null, rpCurrentRouteData = null;
let rpMapInitialized = false, rpIsCalculating = false;
const rpSearchCache = new Map();
const RP_CACHE_EXPIRY = 3600000;
let rpPendingSearchCtrl = null;

function rpDebounce(func, wait) {
  let timeout;
  return function(...args) {
    clearTimeout(timeout);
    timeout = setTimeout(() => func(...args), wait);
  };
}

function rpInitMap() {
  rpMap = L.map('rp-map', {
    attributionControl: false, zoomControl: true, preferCanvas: true, tap: true, touchZoom: true
  }).setView([20.5937, 78.9629], 5);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19, updateWhenIdle: true, keepBuffer: 2 }).addTo(rpMap);
  let resizeTimeout;
  window.addEventListener('resize', () => { clearTimeout(resizeTimeout); resizeTimeout = setTimeout(() => rpMap.invalidateSize(), 250); });
  window.addEventListener('orientationchange', () => { setTimeout(() => rpMap.invalidateSize(), 300); });
}

async function rpSearchLocation(query, callback) {
  if (query.length < 3) { callback([]); return; }
  const key = query.toLowerCase();
  const cached = rpSearchCache.get(key);
  if (cached && (Date.now() - cached.timestamp) < RP_CACHE_EXPIRY) { callback(cached.data); return; }
  if (rpPendingSearchCtrl) rpPendingSearchCtrl.abort();
  try {
    rpPendingSearchCtrl = new AbortController();
    const tid = setTimeout(() => rpPendingSearchCtrl.abort(), 5000);
    const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&countrycodes=in&limit=8&addressdetails=1`, { signal: rpPendingSearchCtrl.signal });
    clearTimeout(tid);
    const data = await res.json();
    rpSearchCache.set(key, { data, timestamp: Date.now() });
    rpPendingSearchCtrl = null;
    callback(data);
  } catch(e) {
    if (e.name !== 'AbortError') console.error('Search error:', e);
    callback([]);
  }
}

const rpDebouncedSearch = rpDebounce((query, cb) => rpSearchLocation(query, cb), 500);

function rpSetupAutocomplete(inputId, suggestionsId, coordsCb) {
  const input = document.getElementById(inputId);
  const list  = document.getElementById(suggestionsId);
  input.addEventListener('input', function() {
    const q = this.value.trim();
    if (q.length < 3) { list.classList.remove('active'); return; }
    rpDebouncedSearch(q, results => {
      list.innerHTML = '';
      if (!results.length) { list.classList.remove('active'); return; }
      const frag = document.createDocumentFragment();
      results.forEach(r => {
        const item = document.createElement('div');
        item.className = 'suggestion-item';
        item.innerHTML = `<div class="suggestion-name">${r.display_name.split(',')[0]}</div><div class="suggestion-detail">${r.display_name}</div>`;
        item.addEventListener('click', e => {
          e.stopPropagation();
          input.value = r.display_name;
          coordsCb({ lat: parseFloat(r.lat), lon: parseFloat(r.lon), name: r.display_name });
          list.classList.remove('active');
        });
        frag.appendChild(item);
      });
      list.appendChild(frag);
      list.classList.add('active');
    });
  });
  document.addEventListener('click', e => {
    if (!input.contains(e.target) && !list.contains(e.target)) list.classList.remove('active');
  });
}

async function rpCalculateRoute() {
  if (!rpOriginCoords || !rpDestCoords) { rpShowError('Please select both origin and destination from the suggestions.'); return; }
  if (rpIsCalculating) return;
  rpIsCalculating = true;
  document.getElementById('rp-loading').classList.add('active');
  document.getElementById('rp-error').classList.remove('active');
  document.getElementById('rp-routeResult').classList.remove('active');
  document.getElementById('rp-landmarksCard').style.display = 'none';
  document.getElementById('rp-calculateBtn').disabled = true;
  try {
    const ctrl = new AbortController();
    const tid = setTimeout(() => ctrl.abort(), 10000);
    const res = await fetch(`https://router.project-osrm.org/route/v1/driving/${rpOriginCoords.lon},${rpOriginCoords.lat};${rpDestCoords.lon},${rpDestCoords.lat}?overview=full&geometries=geojson&steps=true&alternatives=true`, { signal: ctrl.signal });
    clearTimeout(tid);
    const data = await res.json();
    if (data.code !== 'Ok' || !data.routes?.length) throw new Error('No route found');
    rpCurrentRouteData = data.routes[0];
    rpDisplayRoute(rpCurrentRouteData);
    setTimeout(() => rpFindLandmarks(rpCurrentRouteData), 100);
  } catch(e) {
    rpShowError(e.name === 'AbortError' ? 'Request timeout. Please try again.' : 'Could not calculate route. Please try different locations.');
  } finally {
    document.getElementById('rp-loading').classList.remove('active');
    document.getElementById('rp-calculateBtn').disabled = false;
    rpIsCalculating = false;
  }
}

function rpDisplayRoute(route) {
  if (rpRouteLayer) rpMap.removeLayer(rpRouteLayer);
  if (rpOriginMarker) rpMap.removeLayer(rpOriginMarker);
  if (rpDestMarker) rpMap.removeLayer(rpDestMarker);
  const coords = route.geometry.coordinates.map(c => [c[1], c[0]]);
  rpRouteLayer = L.polyline(coords, { color: '#E3B209', weight: 6, opacity: 0.85, smoothFactor: 1 }).addTo(rpMap);
  const mkA = L.divIcon({ className: '', html: '<div style="background:linear-gradient(135deg,#2E9E6B,#66BB6A);width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.3);font-size:13px;">A</div>', iconSize:[34,34] });
  const mkB = L.divIcon({ className: '', html: '<div style="background:linear-gradient(135deg,#D94F2E,#EF5350);width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.3);font-size:13px;">B</div>', iconSize:[34,34] });
  rpOriginMarker = L.marker([rpOriginCoords.lat, rpOriginCoords.lon], {icon:mkA}).addTo(rpMap);
  rpDestMarker   = L.marker([rpDestCoords.lat,   rpDestCoords.lon],   {icon:mkB}).addTo(rpMap);
  rpMap.fitBounds(rpRouteLayer.getBounds(), { padding:[50,50], animate:true, duration:0.5 });
  const distKm   = (route.distance / 1000).toFixed(1);
  const durH     = Math.floor(route.duration / 3600);
  const durM     = Math.floor((route.duration % 3600) / 60);
  const tolls    = Math.max(1, Math.floor(route.distance / 100000));
  requestAnimationFrame(() => {
    document.getElementById('rp-distance').textContent = distKm + ' km';
    document.getElementById('rp-duration').textContent = durH > 0 ? `${durH}h ${durM}m` : `${durM}m`;
    document.getElementById('rp-tolls').textContent    = tolls;
    document.getElementById('rp-originAddr').textContent = rpOriginCoords.name;
    document.getElementById('rp-destAddr').textContent   = rpDestCoords.name;
    document.getElementById('rp-routeResult').classList.add('active');
  });
}

async function rpFindLandmarks(route) {
  try {
    const coords = route.geometry.coordinates;
    const total  = coords.length;
    const idxs   = [0.2,0.35,0.5,0.65,0.8].map(r => Math.floor(total*r));
    const landmarks = [];
    for (let i=0; i<Math.min(idxs.length,5); i++) {
      const [lon,lat] = coords[idxs[i]];
      try {
        const ctrl = new AbortController();
        const tid  = setTimeout(() => ctrl.abort(), 3000);
        const res  = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=10`, {signal:ctrl.signal});
        clearTimeout(tid);
        const data = await res.json();
        if (data?.display_name) {
          const parts = data.display_name.split(',');
          const name  = parts[0].trim() || parts[1]?.trim() || 'Checkpoint';
          const type  = data.address?.city ? 'City' : data.address?.town ? 'Town' : data.address?.village ? 'Village' : data.address?.industrial ? 'Industrial Area' : 'Waypoint';
          landmarks.push({name, type});
        }
      } catch(e) { if (e.name!=='AbortError') console.error('Landmark error:',e); }
      await new Promise(r => setTimeout(r, 1000));
    }
    rpDisplayLandmarks(landmarks);
  } catch(e) { rpDisplayLandmarks([]); }
}

function rpDisplayLandmarks(landmarks) {
  const list = document.getElementById('rp-landmarksList');
  requestAnimationFrame(() => {
    list.innerHTML = '';
    if (!landmarks.length) {
      list.innerHTML = '<div style="text-align:center;color:var(--text-light);font-size:12px;padding:8px;">No landmarks found along this route.</div>';
    } else {
      const frag = document.createDocumentFragment();
      landmarks.forEach(lm => {
        const el = document.createElement('div');
        el.className = 'rp-landmark-item';
        el.innerHTML = `<div class="rp-landmark-name">${lm.name}</div><div class="rp-landmark-type">${lm.type}</div>`;
        frag.appendChild(el);
      });
      list.appendChild(frag);
    }
    document.getElementById('rp-landmarksCard').style.display = 'block';
  });
}

function rpToggleLandmarks() {
  const body    = document.getElementById('rp-landmarksBody');
  const chevron = document.getElementById('rp-chevron');
  const toggle  = document.getElementById('rp-landmarksToggle');
  const open    = body.classList.toggle('open');
  chevron.classList.toggle('open', open);
  toggle.classList.toggle('open', open);
}

function rpConfirmAndProceed() {
  if (!rpCurrentRouteData || !rpOriginCoords || !rpDestCoords) {
    rpShowError('Route not calculated yet. Please calculate route first.');
    return;
  }
  const distKm = (rpCurrentRouteData.distance / 1000).toFixed(1);
  const durH   = Math.floor(rpCurrentRouteData.duration / 3600);
  const durM   = Math.floor((rpCurrentRouteData.duration % 3600) / 60);
  const tolls  = Math.max(1, Math.floor(rpCurrentRouteData.distance / 100000));
  const params = new URLSearchParams({
    origin:      rpOriginCoords.name,
    destination: rpDestCoords.name,
    originLat:   rpOriginCoords.lat,
    originLon:   rpOriginCoords.lon,
    destLat:     rpDestCoords.lat,
    destLon:     rpDestCoords.lon,
    distance:    distKm,
    duration:    durH > 0 ? `${durH}h ${durM}m` : `${durM}m`,
    tolls,
    approved:    'true'
  });
  window.location.href = `https://roshitrans.github.io/Track/?${params.toString()}`;
}

function rpShowError(msg) {
  const el = document.getElementById('rp-error');
  requestAnimationFrame(() => { el.textContent = msg; el.classList.add('active'); });
  setTimeout(() => requestAnimationFrame(() => el.classList.remove('active')), 5000);
}

